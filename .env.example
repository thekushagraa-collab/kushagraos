# KushagraOS — server-side secrets. Copy this file to ".env.local" (which is
# gitignored via "*.local") and paste your real keys there. NEVER commit real
# keys; NEVER expose them to the client (no VITE_ prefix — these stay server-side
# and are only read inside /api handlers + the Vite dev middleware).

# Groq (console.groq.com → API Keys). Free, no card, works instantly. Preferred
# brain for /api/ask — OpenAI-compatible, fast Llama models. Key format "gsk_…".
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Studio → "Get API key". Used only if GROQ_API_KEY is empty. Powers
# Gemini TTS (/api/tts) when set. (Free tier may be unavailable in some regions.)
GEMINI_API_KEY=

# Optional: model overrides (sane defaults if unset).
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Optional: contact form real submit (Web3Forms free access key). If unset, the
# Contact app gracefully falls back to its success toast only.
WEB3FORMS_ACCESS_KEY=

# Founder Mode passphrase (Phase H). The private control surface is unlocked by
# POSTing this exact string to /api/founder. If unset, Founder Mode is SEALED
# (every attempt is denied) — that is the secure default. Set a strong value in
# .env.local for local use and in your host's env (e.g. Vercel) for production.
FOUNDER_KEY=
